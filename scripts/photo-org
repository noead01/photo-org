#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
python_bin="${repo_root}/.venv/bin/python"

if [[ ! -x "${python_bin}" ]]; then
  echo "Expected Python interpreter at ${python_bin}. Run 'uv sync --group dev --group test' from ${repo_root}." >&2
  exit 1
fi

export PYTHONPATH="${repo_root}/apps/api${PYTHONPATH:+:${PYTHONPATH}}"
export PYTHONPATH="${repo_root}/apps/cli:${PYTHONPATH}"

exec "${python_bin}" -m cli "$@"
